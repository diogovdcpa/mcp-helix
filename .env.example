# Copy to .env and fill with real values before starting the MCP server.
TRELLIX_CLIENT_ID=
TRELLIX_CLIENT_SECRET=
TRELLIX_API_KEY=

# Typical Trellix defaults. Adjust only if your tenant uses different endpoints.
TRELLIX_TOKEN_ENDPOINT=https://iam.cloud.trellix.com/iam/v1.0/token
API_BASE_URL=https://xdr.trellix.com

# Optional runtime settings.
TIMEOUT_SECONDS=60
MCP_HELIX_LOG_LEVEL=INFO
